# Automatic HTTPS via Let's Encrypt. DOMAIN + ACME_EMAIL come from the .env file.
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	# Social unfurlers (WhatsApp/Telegram/Twitter/…) can't run JS, so serve them
	# server-rendered Open Graph HTML for shared polls & lists. Humans still get the SPA.
	@unfurl {
		path /poll/* /s/*
		header_regexp User-Agent (?i)(facebookexternalhit|twitterbot|whatsapp|telegrambot|slackbot|discordbot|linkedinbot|pinterest|redditbot|embedly|vkshare|skypeuripreview)
	}
	handle @unfurl {
		rewrite * /og{uri}
		reverse_proxy backend:8070
	}

	# Backend API
	handle /api/* {
		reverse_proxy backend:8070
	}

	# Frontend SPA (everything else)
	handle {
		reverse_proxy frontend:80
	}
}
