# ---- Database ----
POSTGRES_DB=nearpoint
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---- Google API keys ----
# Backend: server-side Places API key (Places API enabled)
GOOGLE_PLACES_API_KEY=
# Frontend: browser Maps JavaScript API key (Maps JavaScript API enabled)
REACT_APP_GOOGLE_MAPS_API_KEY=

# ---- Cloudflare Turnstile (bot protection; leave both empty to disable) ----
# Frontend widget site key
REACT_APP_TURNSTILE_SITE_KEY=
# Backend secret key (used to verify tokens server-side)
TURNSTILE_SECRET_KEY=

# ---- Optional API-key auth for /api/** (blank = public demo) ----
API_KEY=

# ---- Monetization (optional) ----
# Booking.com affiliate id appended to hotel "Book" links
REACT_APP_BOOKING_AID=
# Comma-separated placeIds shown with a "Featured" badge
REACT_APP_FEATURED_PLACE_IDS=

# ---- Web Push (optional; generate with: npx web-push generate-vapid-keys) ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---- URLs (local docker-compose.yml only) ----
# Where the browser reaches the backend
REACT_APP_API_BASE_URL=http://localhost:8070
# Comma-separated origins allowed to call the backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ---- Production (docker-compose.prod.yml only) ----
# Your public domain (DNS A record must point to the VPS). No http/https prefix.
DOMAIN=example.com
# Email for Let's Encrypt certificate notices
ACME_EMAIL=you@example.com
